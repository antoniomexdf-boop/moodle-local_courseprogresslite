{{!
    @template local_courseprogresslite/progress_widget

    Simple course progress widget.

    Context variables required for this template:
    * label string
    * value int
    * percentage string
    * maxlabel string
    * showpercentage bool
    * progressbarlabel string

    Example context (json):
    {
        "label": "Your course progress",
        "value": 65,
        "percentage": "65%",
        "maxlabel": "100%",
        "showpercentage": true,
        "progressbarlabel": "Course progress: 65%"
    }
}}
<div class="local-courseprogresslite__title">{{label}}</div>
<div class="local-courseprogresslite__track" role="progressbar" aria-label="{{progressbarlabel}}" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{value}}">
    <span class="local-courseprogresslite__fill" style="width: {{value}}%;"></span>
</div>
<div class="local-courseprogresslite__meta">
    <div class="local-courseprogresslite__value">
        {{#showpercentage}}{{percentage}}{{/showpercentage}}
    </div>
    <div class="local-courseprogresslite__max">{{maxlabel}}</div>
</div>
